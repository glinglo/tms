# Local only: where `vercel dev` runs (default 3000; use 3001 if port 3000 is busy)
# VITE_DEV_API_ORIGIN=http://localhost:3001

# Public site URL (production)
SITE_URL=https://www.themapscraper.com
VITE_SITE_URL=https://www.themapscraper.com

# Client (Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server (Vercel / vercel dev) — required for /api/scrape, /api/credits, /api/deduct-credits
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_secret

APIFY_API_TOKEN=apify_api_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
